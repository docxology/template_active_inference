# Active Inference exemplar configuration template
# Copy to config.yaml and customize. See docs/guides/zenodo-doi-strategy.md for split DOI layout.

paper:
  title: "Your Active Inference Research Title"
  subtitle: "Optional subtitle"
  version: "0.1.0"
  date: ""

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"
    email: "your.email@example.com"
    affiliation: "Your Institution"
    corresponding: true

publication:
  doi: ""  # Concept DOI — stable citation; PDF cover and CITATION.cff
  version_doi: ""  # Latest Zenodo version DOI
  version_record: ""  # https://zenodo.org/records/{id}
  github_repository: ""  # e.g. docxology/template_active_inference
  transmission_bookends:
    enabled: false
    max_prior_releases: 5
    show_steganography: true

keywords:
  - "active inference"

metadata:
  license: "MIT"
  language: "en"
  # Optional page geometry forwarded to pandoc as `-V geometry:` (see config.yaml)
  # geometry: "margin=0.5in"

render:
  formats:
    pdf: true
    html: true
    slides: false

llm:
  reviews:
    enabled: false
  translations:
    enabled: false

testing:
  max_test_failures: 0

analysis:
  scripts:
    - compose_manuscript.py
    - run_analytical_sweep.py
    - simulate_si_tmaze.py
    - simulate_si_graph_world.py
    - compute_statistics.py
    - generate_figures.py
    - render_animation.py
    - generate_validation_spine.py
    - generate_toy_sweep_tracks.py
    - generate_formal_interop_tracks.py
    - generate_integration_audit.py
    - generate_sheaf_tracks.py
    - z_generate_manuscript_variables.py

sheaf:
  manifest: "manuscript/sheaf/manifest.yaml"
  registry: "manuscript/sheaf/tracks.yaml"
  coverage_config: "manuscript/sheaf/coverage.yaml"
  composer: "scripts/compose_manuscript.py"
  figures_config: "figures.yaml"
